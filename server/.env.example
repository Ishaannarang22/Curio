# Copy to .env  ->  cp .env.example .env  (server/.env is gitignored)
#
# Redis connection string.
#
# Local Docker (default if left unset):
#   redis://localhost:6379
#
# Redis Cloud — NO Docker needed. From your database's "Connect" panel, copy the
# redis-cli / connection URL. It looks like:
#   redis://default:<password>@<host>.<region>.redns.redis-cloud.com:<port>
# Use rediss:// (two s) instead of redis:// if your database has TLS enabled.
REDIS_URL=
