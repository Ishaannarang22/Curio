# Copy to .env.local and fill in. .env.local is gitignored and is read by BOTH
# the Next.js app and the Python voice agent (agent/bot.py loads it explicitly).

# =============================================================================
# Sentry — error monitoring + tracing (web app + voice agent)
# =============================================================================

# DSN from Project Settings > Client Keys (DSN) in Sentry. Safe to expose client-side.
NEXT_PUBLIC_SENTRY_DSN=

# Needed only for source map uploads during `next build`.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Voice agent (Python) Sentry. Optional — falls back to NEXT_PUBLIC_SENTRY_DSN.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=1.0

# =============================================================================
# Voice pipeline (the Pipecat agent in agent/ reads these)
# =============================================================================

DEEPGRAM_API_KEY=your-deepgram-key        # ears: Flux STT + semantic turn-taking
CARTESIA_API_KEY=your-cartesia-key        # voice: Sonic-3 TTS

# --- The brain (first configured wins: Gateway > NVIDIA > Z.ai / OpenAI-compatible) ---
# Option A: Vercel AI Gateway — one key, 280+ models, pick per session via payload.
# AI_GATEWAY_API_KEY=your-gateway-key
# AI_GATEWAY_MODEL=openai/gpt-4o-mini
# Option B: NVIDIA NIM (Nemotron — thinking disabled for voice).
# NVIDIA_API_KEY=your-nvidia-key
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=nvidia/nemotron-3-nano-30b-a3b
# Option C: any OpenAI-compatible endpoint (e.g. Z.ai / GLM)
# ZAI_API_KEY=your-zai-key
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
# ZAI_MODEL=glm-5.1

# =============================================================================
# Supabase (auth + message persistence) — creds to be added once the DB exists
# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Optional ---
# NEXT_PUBLIC_VOICE_AGENT_URL=http://localhost:7860   # where the Pipecat bot runs
